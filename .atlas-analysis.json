  "keyFeatures": [
    "Structured log format with microsecond-precision timestamps",
    "Automatic exception traceback capture (file, line, message)",
    "Colorized console output via chromolog dependency",
    "Automatic caller script detection for default log file placement",
    "Support for relative and absolute log file paths via pathlib",
    "Append-mode file writes — no log data is ever overwritten",
    "Internal logging system for module-level errors",
    "Zero-config default: Logger() works out of the box"
  ],
